{
  "name": "@gsvarovsky/deciduous",
  "version": "0.0.2",
  "description": "App that simplifies building decision trees to model adverse scenarios",
  "main": "layout.js",
  "directories": {
    "example": "examples"
  },
  "type": "module",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && npm run test",
    "test": "node --import tsx --test test/**/*.test.ts",
    "dev": "concurrently \"tsc --watch\" \"browser-sync start -s -f --no-open **/*\""
  },
  "bin": {
    "deciduous": "cli-cjs.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rpetrich/deciduous.git"
  },
  "keywords": [
    "attack",
    "decision",
    "tree",
    "security"
  ],
  "author": "Ryan Petrich <rpetrich@gmail.com> and Kelly Shortridge",
  "license": "GPLv2",
  "bugs": {
    "url": "https://github.com/rpetrich/deciduous/issues"
  },
  "homepage": "https://github.com/rpetrich/deciduous#readme",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@hpcc-js/wasm": "^2.15.3",
    "csv-stringify": "^6.6.0",
    "js-yaml": "^4.1.1",
    "svg2img": "^1.0.0-beta.2"
  }
}
